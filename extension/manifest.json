{
  "manifest_version": 3,
  "name": "Sider - Анализ стресса",
  "version": "1.0",
  "description": "Анализирует вкладки и помогает снизить стресс",
  "permissions": ["tabs", "storage", "sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Открыть анализ стресса"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}